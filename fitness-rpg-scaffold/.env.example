# .env.example
# Copy this file to apps/api/.env and apps/web/.env and fill in values.
# Never commit .env files. This file is safe to commit.

# ─── Backend (apps/api/.env) ────────────────────────────────────────────────

API_PORT=3001

# Supabase — get from your project's Settings > API
API_SUPABASE_URL=https://your-project.supabase.co
API_SUPABASE_SERVICE_ROLE_KEY=   # NEVER expose this to the frontend

# Strava — get from https://www.strava.com/settings/api
API_STRAVA_CLIENT_ID=
API_STRAVA_CLIENT_SECRET=
API_STRAVA_WEBHOOK_VERIFY_TOKEN= # A random string you choose (e.g. run: openssl rand -hex 20)

# Coros — get from https://developer.coros.com after approval
API_COROS_CLIENT_ID=
API_COROS_CLIENT_SECRET=

# Anthropic — get from https://console.anthropic.com
API_ANTHROPIC_API_KEY=

# ─── Frontend (apps/web/.env) ────────────────────────────────────────────────

# The URL where your backend API is running
VITE_API_URL=http://localhost:3001

# Supabase — get from your project's Settings > API
# These are safe to expose to the frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
